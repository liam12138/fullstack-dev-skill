{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["src/core/*"],
      "@qa-engine/*": ["src/qa-engine/*"],
      "@doc-generator/*": ["src/doc-generator/*"],
      "@code-generator/*": ["src/code-generator/*"],
      "@platform-adapters/*": ["src/platform-adapters/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "templates"]
}
